@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="row">
    <div class="col-md-6">
        <h2 class="mb-4">Quên Mật Khẩu</h2>

        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-info">@Model.StatusMessage</div>
            }

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email đã đăng ký</label>
                <input asp-for="Input.Email" class="form-control" placeholder="Nhập email của bạn" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Kiểm tra email</button>
        </form>

        @if (Model.EmailExists && !string.IsNullOrEmpty(Model.EmailChecked))
        {
            <hr />
            <div class="alert alert-success">
                Email hợp lệ và đã được đăng ký.
            </div>

            <form method="post" asp-page-handler="SendCode">
                <input type="hidden" name="email" value="@Model.EmailChecked" />
                <button type="submit" class="btn btn-success">Gửi mã xác nhận</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
