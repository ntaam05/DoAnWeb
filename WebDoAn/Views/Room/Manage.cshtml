@model WebDoAn.Models.ManageRoomViewModel

@{
    ViewData["Title"] = "Quản lý phòng";
}

<style>
    :root {
        --primary-teal: #009688;
        --primary-teal-hover: #00796b;
    }

    .text-teal {
        color: var(--primary-teal) !important;
    }

    .bg-teal {
        background-color: var(--primary-teal) !important;
    }

    .btn-teal {
        background-color: var(--primary-teal);
        color: white;
        border: none;
        transition: 0.2s;
    }

        .btn-teal:hover {
            background-color: var(--primary-teal-hover);
            color: white;
        }

    .btn-outline-teal {
        color: var(--primary-teal);
        border-color: var(--primary-teal);
        transition: 0.2s;
    }

        .btn-outline-teal:hover {
            background-color: var(--primary-teal);
            color: white;
        }

    .focus-teal:focus {
        border-color: var(--primary-teal);
        box-shadow: 0 0 0 0.25rem rgba(0, 150, 136, 0.25);
    }

    /* Gradient cho thẻ Mã tham gia */
    .join-code-card {
        background: linear-gradient(135deg, #ffffff 0%, #e0f2f1 100%);
        border-left: 5px solid var(--primary-teal) !important;
    }

    /* Hiệu ứng thẻ người thuê */
    .tenant-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 16px;
    }

        .tenant-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important;
        }

    .code-box-display {
        background: white;
        border: 1px dashed #ccc;
        border-radius: 50px;
        padding: 5px 10px 5px 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="container py-4 mb-5">

    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
        <a href="/Room/MyRooms" class="btn btn-light rounded-circle shadow-sm me-3" title="Trở về">
            <i class="bi bi-arrow-left fs-5"></i>
        </a>
        <h2 class="fw-bold text-teal m-0">
            <i class="bi bi-house-gear-fill me-2"></i> Quản lý: <span class="text-dark">@Model.Room?.Title</span>
        </h2>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-5 join-code-card">
        <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h5 class="fw-bold mb-1 text-dark"><i class="bi bi-key-fill text-warning me-2"></i>Mã tham gia phòng</h5>
                <p class="text-muted small m-0">Gửi mã này cho người thuê để họ tự động tham gia vào phòng của bạn.</p>
            </div>

            <div class="code-box-display shadow-sm">
                <code id="joinCodeBox" class="fs-5 text-teal fw-bold mb-0" style="letter-spacing: 1px;">@Model.Room?.JoinCode</code>

                <button type="button" class="btn btn-light rounded-circle shadow-sm ms-2" id="btnCopyCode" title="Copy mã">
                    <i class="bi bi-clipboard" id="copyIcon"></i>
                </button>

                <button type="button" class="btn btn-teal rounded-pill px-3 shadow-sm" id="btnGenerateCode" data-room-id="@Model.Room?.Id">
                    <i class="bi bi-arrow-repeat"></i> Tạo mã mới
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-teal m-0"><i class="bi bi-person-plus-fill me-2"></i>Thêm khách thuê thủ công</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="AddTenant" enctype="multipart/form-data">
                        <input type="hidden" name="roomPostId" value="@Model.Room?.Id" />

                        <div class="mb-3">
                            <label class="form-label text-muted fw-semibold small">Họ và tên</label>
                            <input name="name" class="form-control focus-teal" placeholder="Nhập họ tên người thuê..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted fw-semibold small">Email (Đã đăng ký tài khoản)</label>
                            <input name="email" type="email" class="form-control focus-teal" placeholder="name@example.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted fw-semibold small">Số điện thoại</label>
                            <input name="phone" class="form-control focus-teal" placeholder="09xxxx..." required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted fw-semibold small">Avatar (Tùy chọn)</label>
                            <input name="avatar" type="file" class="form-control focus-teal" accept="image/*" />
                        </div>

                        <button type="submit" class="btn btn-teal w-100 rounded-pill py-2 fw-bold shadow-sm">
                            <i class="bi bi-check2-circle me-1"></i> Thêm vào phòng
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold m-0"><i class="bi bi-people-fill text-teal me-2"></i>Danh sách người đang thuê</h5>
                <span class="badge bg-light text-teal border rounded-pill px-3 py-2">
                    Tổng số: @(Model.Tenants?.Count() ?? 0) người
                </span>
            </div>

            @if (Model.Tenants == null || !Model.Tenants.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 text-center py-5 bg-light mt-3">
                    <div class="card-body py-4">
                        <i class="bi bi-person-x text-muted opacity-25 d-block mb-3" style="font-size: 4rem;"></i>
                        <h5 class="text-muted fw-bold">Phòng trống</h5>
                        <p class="text-muted mb-0 small">Chưa có ai thuê phòng này. Hãy gửi Mã tham gia hoặc thêm thủ công nhé!</p>
                    </div>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var tenant in Model.Tenants)
                    {
                        <div class="col">
                            <div class="card border-0 shadow-sm h-100 tenant-card">
                                <div class="card-body text-center p-4">
                                    <div class="position-relative d-inline-block mb-3">
                                        <img src="@tenant.AvatarUrl"
                                             class="rounded-circle border border-3 border-white shadow-sm"
                                             style="width:90px; height:90px; object-fit:cover;"
                                             alt="Avatar"
                                             onerror="this.onerror=null;this.src='https://i.pravatar.cc/150?img=3';" />
                                    </div>

                                    <h6 class="fw-bold mb-1 text-dark">@tenant.Name</h6>
                                    <div class="text-muted small mb-1"><i class="bi bi-envelope me-1"></i>@tenant.Email</div>
                                    <div class="text-muted small mb-3"><i class="bi bi-telephone me-1"></i>@tenant.Phone</div>

                                    <form method="post" asp-action="DeleteTenant">
                                        <input type="hidden" name="roomPostId" value="@Model.Room?.Id" />
                                        <input type="hidden" name="tenantId" value="@tenant.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold"
                                                onclick="return confirm('Bạn có chắc muốn xóa người thuê @tenant.Name ra khỏi phòng này?')">
                                            <i class="bi bi-trash3 me-1"></i> Xóa khách
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý tạo mã mới (Ajax)
        document.getElementById("btnGenerateCode")?.addEventListener("click", async function () {
            const roomId = this.getAttribute("data-room-id");
            const btn = this;
            const originalHtml = btn.innerHTML;

            // Hiệu ứng đang tải
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tạo...';
            btn.disabled = true;

            try {
                const response = await fetch('/Room/RegenerateJoinCodeAjax', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'roomPostId=' + encodeURIComponent(roomId)
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById("joinCodeBox").textContent = data.joinCode;
                } else {
                    alert(data.message || "Không tạo được mã.");
                }
            } catch (error) {
                alert("Lỗi kết nối.");
            } finally {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });

        // Xử lý Copy mã xịn xò (đổi icon)
        document.getElementById("btnCopyCode")?.addEventListener("click", async function () {
            const code = document.getElementById("joinCodeBox")?.textContent?.trim();
            if (!code) return;

            try {
                await navigator.clipboard.writeText(code);
                const icon = document.getElementById("copyIcon");
                const btn = this;

                // Đổi thành icon Check màu xanh
                icon.className = "bi bi-check-lg text-success fs-5";

                // Trả lại icon cũ sau 2 giây
                setTimeout(() => {
                    icon.className = "bi bi-clipboard";
                }, 2000);
            } catch (err) {
                alert("Lỗi khi copy mã.");
            }
        });
    </script>
}