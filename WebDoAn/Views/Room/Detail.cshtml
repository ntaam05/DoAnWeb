@model WebDoAn.Models.RoomPost
@using Microsoft.AspNetCore.Http

@{
    var email = Context.Session.GetString("CURRENT_USER_EMAIL");
    var type = Context.Session.GetString("CURRENT_USER_TYPE");
    var comments = ViewBag.Comments as List<WebDoAn.Models.RoomComment>;
    double avg = ViewBag.AvgRate ?? 0.0;
    bool isSaved = ViewBag.IsSaved != null && (bool)ViewBag.IsSaved;

    var images = (Model.ImageUrls != null && Model.ImageUrls.Any())
        ? Model.ImageUrls
        : new List<string> { "https://picsum.photos/seed/defaultroom/900/500" };
}

<div class="row g-4">
    <div class="col-lg-7">
        <div id="roomCarousel" class="carousel slide" data-bs-ride="carousel">
            @if (images.Count > 1)
            {
                <div class="carousel-indicators">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button type="button"
                                data-bs-target="#roomCarousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
            }

            <div class="carousel-inner">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@images[i]"
                             class="d-block w-100 rounded shadow"
                             style="height:400px; object-fit:cover;"
                             alt="Ảnh phòng @(i + 1)"
                             onerror="this.onerror=null;this.src='https://picsum.photos/seed/defaultroom/900/500';" />
                    </div>
                }
            </div>

            @if (images.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <h2>@Model.Title</h2>

        <div class="fs-4 fw-bold text-primary">
            @String.Format("{0:N0} đ", Model.Price)
        </div>

        <p class="mt-3">@Model.Description</p>

        <div class="mt-3 mb-3">
            ⭐ <b>@avg</b> / 5
        </div>

        @if (!string.IsNullOrEmpty(email))
        {
            @if (!isSaved)
            {
                <form method="post" asp-action="SaveRoom">
                    <input type="hidden" name="roomId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger">Lưu phòng</button>
                </form>
            }
            else
            {
                <form method="post" asp-action="UnsaveRoom">
                    <input type="hidden" name="roomId" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Bỏ lưu</button>
                </form>
            }
        }
    </div>
</div>

<hr />

<h4>Bình luận & Đánh giá</h4>

@if (email != null && type == "Tenant")
{
    <form method="post" asp-action="AddComment" asp-route-id="@Model.Id" class="mb-4">
        <div class="mb-2">
            <textarea name="content" class="form-control" placeholder="Nhận xét..." required></textarea>
        </div>

        <div class="mb-2">
            <select name="rating" class="form-select" required>
                <option value="">Chọn số sao</option>
                <option value="5">⭐⭐⭐⭐⭐ - Rất tốt</option>
                <option value="4">⭐⭐⭐⭐ - Tốt</option>
                <option value="3">⭐⭐⭐ - Bình thường</option>
                <option value="2">⭐⭐ - Tệ</option>
                <option value="1">⭐ - Rất tệ</option>
            </select>
        </div>

        <button class="btn btn-primary">Gửi đánh giá</button>
    </form>
}

@if (comments != null && comments.Count > 0)
{
    @foreach (var c in comments.OrderByDescending(x => x.CreatedAt))
    {
        <div class="border rounded p-3 mb-2 shadow-sm">
            <div class="fw-bold">@c.UserEmail</div>
            <div>⭐ @c.Rating / 5</div>
            <div>@c.Content</div>
            <div class="text-muted small">@c.CreatedAt</div>
        </div>
    }
}
else
{
    <div class="text-muted">Chưa có bình luận nào.</div>
}