@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebDoAn</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebDoAn.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-teal: #009688;
            --primary-teal-hover: #00796b;
            --dark-bg: #1a2a36;
        }
        .navbar-custom { background-color: var(--primary-teal); }
        .navbar-custom .nav-link, .navbar-custom .navbar-brand { color: white !important; font-weight: 500; }
        .navbar-custom .nav-link:hover { color: #e0e0e0 !important; }
        .footer-custom { background-color: var(--dark-bg); color: #a0aec0; }
        .footer-custom a { color: #a0aec0; text-decoration: none; }
        .footer-custom a:hover { color: white; }
        .footer-teal-bar { background-color: var(--primary-teal); color: white; padding: 15px 0; }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom box-shadow py-3">
            <div class="container">
                <!-- ✅ Absolute URL: luôn về / bất kể đang ở đâu -->
                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <i class="bi bi-house-heart-fill fs-3"></i>
                    <span class="fw-bold fs-4">DoAnWeb</span>
                </a>

                <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <!-- ✅ Absolute URLs -->
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Privacy">Về chúng tôi</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Room/FindFeed">Tìm ở ghép</a></li>
                    </ul>

                    @{
                        var email = Context.Session.GetString("CURRENT_USER_EMAIL");
                        var type = Context.Session.GetString("CURRENT_USER_TYPE");
                    }

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                        @if (!string.IsNullOrEmpty(email))
                        {
                            @if (type == "Landlord")
                            {
                                <li class="nav-item"><a class="nav-link" href="/Room/Create">Đăng phòng</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Room/MyRooms">Quản lý phòng</a></li>
                            }
                            else if (type == "Tenant")
                            {
                                <li class="nav-item"><a class="nav-link" href="/Room/CreateFind">Đăng bài tìm người</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Room/Saved"><i class="bi bi-heart-fill"></i> Đã lưu</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Profile/Index">Hồ sơ</a></li>
                            }

                            @if (!string.IsNullOrEmpty(email) && type == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/Dashboard"><i class="bi bi-gear"></i> Admin</a>
                                </li>
                            }

                            <li class="nav-item ms-lg-3">
                                <span class="nav-link fw-bold text-warning border border-warning rounded px-3 py-1">
                                    <i class="bi bi-person-circle"></i> @email
                                </span>
                            </li>

                            <li class="nav-item">
                                <form method="post"
                                      asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      asp-route-returnUrl="~/"
                                      class="d-inline" style="display:inline;">
                                    <button type="submit" class="nav-link btn btn-link border-0 text-white p-0 m-0" style="text-decoration:none;">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Identity/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light text-teal fw-bold rounded-pill px-4 ms-lg-2" href="/Identity/Account/Register">Đăng ký ngay</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="flex-fill">
        <main role="main">
            <div class="container mt-3">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["AuthError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @TempData["AuthError"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto">
        <div class="footer-teal-bar text-center">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
                <h5 class="mb-3 mb-md-0 fw-bold">Đăng ký ngay để nhận thông báo phòng mới nhất!</h5>
                <form class="d-flex gap-2">
                    <input type="email" class="form-control rounded-pill" placeholder="Nhập email của bạn...">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4">Gửi</button>
                </form>
            </div>
        </div>

        <div class="footer-custom py-5">
            <div class="container">
                <div class="row gy-4">
                    <div class="col-lg-4 col-md-6">
                        <h4 class="text-white d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-house-heart-fill"></i> DoAnWeb
                        </h4>
                        <p>Nền tảng kết nối người thuê trọ và chủ nhà uy tín, nhanh chóng và minh bạch hàng đầu.</p>
                        <div class="d-flex gap-3 fs-5 mt-3">
                            <a href="#"><i class="bi bi-facebook"></i></a>
                            <a href="#"><i class="bi bi-youtube"></i></a>
                            <a href="#"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <h5 class="text-white mb-3 text-uppercase">Liên kết nhanh</h5>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li><a href="#"><i class="bi bi-chevron-right small"></i> Về chúng tôi</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right small"></i> Quy định sử dụng</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right small"></i> Chính sách bảo mật</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right small"></i> Hướng dẫn đăng tin</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4 col-md-12">
                        <h5 class="text-white mb-3 text-uppercase">Thông tin liên hệ</h5>
                        <ul class="list-unstyled d-flex flex-column gap-3">
                            <li class="d-flex align-items-start gap-3">
                                <i class="bi bi-geo-alt-fill text-teal mt-1"></i>
                                <span>Khu Công nghệ cao, TP. Thủ Đức, TP. HCM</span>
                            </li>
                            <li class="d-flex align-items-center gap-3">
                                <i class="bi bi-telephone-fill text-teal"></i>
                                <span>1900 1234 (Hỗ trợ 24/7)</span>
                            </li>
                            <li class="d-flex align-items-center gap-3">
                                <i class="bi bi-envelope-fill text-teal"></i>
                                <span>support@roommate.vn</span>
                            </li>
                        </ul>
                    </div>
                </div>
                <hr class="border-secondary mt-5 mb-4">
                <div class="text-center small">
                    &copy; 2026 - Bản quyền thuộc về WebDoAn Team.
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>