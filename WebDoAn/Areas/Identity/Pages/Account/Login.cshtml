@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Đăng Nhập</h2>

        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <input asp-for="Input.Password" class="form-control" id="passwordInput" />
                    <button class="btn btn-outline-secondary" type="button" id="togglePasswordBtn">
                        <i class="bi bi-eye" id="toggleIcon">👁️</i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">Nhớ tôi</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Đăng Nhập</button>
            <a asp-page="./ForgotPassword" class="btn btn-link d-block text-center mt-2">Quên mật khẩu?</a>
        </form>

        <hr />
        <p class="text-center">
            Chưa có tài khoản? <a asp-page="./Register">Đăng ký ngay</a>
        </p>
    </div>
</div>

@section Scripts {
    @{ 
        await Html.RenderPartialAsync("_ValidationScriptsPartial"); 
    }
    <script>
        // Toggle ẩn/hiện mật khẩu
        document.getElementById('togglePasswordBtn').addEventListener('click', function () {
            const passwordInput = document.getElementById('passwordInput');
            const toggleIcon = document.getElementById('toggleIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.textContent = '🙈';
            } else {
                passwordInput.type = 'password';
                toggleIcon.textContent = '👁️';
            }
        });
    </script>
}
