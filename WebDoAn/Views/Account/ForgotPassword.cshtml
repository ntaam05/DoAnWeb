@{
    ViewData["Title"] = "Quên mật khẩu";
    var emailChecked = ViewBag.EmailChecked as string;
    var emailExists = ViewBag.EmailExists != null && (bool)ViewBag.EmailExists;
}

<h2 class="mb-3">Quên mật khẩu</h2>

<form method="post" asp-action="ForgotPassword" class="w-50">
    <div class="mb-3">
        <label>Email đã đăng ký</label>
        <input name="email" type="email" class="form-control" value="@emailChecked" placeholder="Nhập gmail của bạn" required />
    </div>

    <button type="submit" class="btn btn-primary">Kiểm tra email</button>
</form>

@if (emailExists)
{
    <hr />
    <div class="w-50">
        <div class="alert alert-success">
            Email hợp lệ và đã được đăng ký.
        </div>

        <form method="post" asp-action="SendResetCode">
            <input type="hidden" name="email" value="@emailChecked" />
            <button type="submit" class="btn btn-success">Gửi mã</button>
        </form>
    </div>
}