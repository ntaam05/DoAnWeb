@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebDoAn</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebDoAn.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    Tinder for Roommates
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Privacy">Privacy</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Room"
                               asp-action="FindFeed">Các bài tìm người</a>
                        </li>
                    </ul>

                    @{
                        var email = Context.Session.GetString("CURRENT_USER_EMAIL");
                        var type = Context.Session.GetString("CURRENT_USER_TYPE");
                    }

                    <ul class="navbar-nav ms-auto">
                        @if (!string.IsNullOrEmpty(email))
                        {
                            @if (type == "Landlord")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Room"
                                       asp-action="Create">Đăng phòng</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Room"
                                       asp-action="MyRooms">My Rooms</a>
                                </li>
                            }
                            else if (type == "Tenant")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Room"
                                       asp-action="CreateFind">Đăng bài tìm người</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Room"
                                       asp-action="Saved">Saved</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Profile"
                                       asp-action="Index">Hồ sơ</a>
                                </li>
                            }

                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    Xin chào, @email (@type)
                                </span>
                            </li>

                            <!-- Thay thế phần logout link -->
                            <li class="nav-item">
                                <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                                    <button type="submit" class="nav-link btn btn-link text-dark border-0">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container flex-fill mt-4">
        <main role="main" class="pb-4">

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Message"]
                </div>
            }

            @if (TempData["AuthError"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["AuthError"]
                </div>
            }

            @RenderBody()

        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top text-muted py-3 mt-auto bg-light">
        <div class="container text-center">
            &copy; 2026 - WebDoAn
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>