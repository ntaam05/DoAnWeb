@{
    ViewData["Title"] = "Khám phá sở thích";
    Layout = null; // Ẩn Navbar để người dùng tập trung chọn Tag
    var currentTags = ViewBag.CurrentTags as string ?? "";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RoomMate - Chọn sở thích của bạn</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .tag-btn {
            padding: 10px 22px;
            margin: 6px;
            border: 2px solid #dee2e6;
            border-radius: 30px;
            background-color: white;
            color: #495057;
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: 600;
            font-size: 0.95rem;
            user-select: none;
        }

            .tag-btn:hover {
                border-color: #009688;
                color: #009688;
            }

            .tag-btn.active {
                background-color: #009688;
                color: white;
                border-color: #009688;
                box-shadow: 0 4px 15px rgba(0, 150, 136, 0.3);
                transform: scale(1.05);
            }

        .onboarding-card {
            max-width: 850px;
            margin: 5vh auto;
            background: white;
            padding: 45px;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="onboarding-card text-center">
            <h2 class="fw-bold mb-3" style="color: #009688;">✨ Bạn đang tìm kiếm điều gì?</h2>
            <p class="text-muted mb-5">Hệ thống sẽ phân tích các lựa chọn này để tính toán độ tương thích và gợi ý cho bạn căn phòng phù hợp nhất.</p>

            <form asp-controller="Profile" asp-action="SaveOnboarding" method="post">

                <h5 class="text-start fw-bold text-dark mb-3"><i class="bi bi-person-heart text-danger"></i> Lối sống & Tính cách</h5>
                <div class="d-flex flex-wrap justify-content-center mb-4">
                    @foreach (var t in new[] { "Sạch sẽ", "Ngủ sớm", "Cú đêm", "Không hút thuốc", "Ít nấu ăn", "Hay nấu ăn", "Yêu động vật", "Hướng nội", "Hướng ngoại", "Hay đi chơi", "Thích yên tĩnh", "Thích thể thao", "Thường xuyên vắng nhà" })
                    {
                        var tagId = "#" + t.Replace(" ", "");
                        <div class="tag-btn @(currentTags.Contains(tagId) ? "active" : "")" data-value="@tagId">@t</div>
                    }
                </div>

                <h5 class="text-start fw-bold text-dark mb-3 mt-4"><i class="bi bi-house-check text-success"></i> Tiện ích phòng mong muốn</h5>
                <div class="d-flex flex-wrap justify-content-center mb-4">
                    @foreach (var t in new[] { "WC riêng", "Có máy lạnh", "Có máy giặt", "Giờ giấc tự do", "Không chung chủ", "Chỗ để xe rộng", "An ninh tốt", "Có gác lửng", "Có ban công", "Gần siêu thị", "Có cửa sổ", "Được nuôi Pet" })
                    {
                        var tagId = "#" + t.Replace(" ", "");
                        <div class="tag-btn @(currentTags.Contains(tagId) ? "active" : "")" data-value="@tagId">@t</div>
                    }
                </div>

                <input type="hidden" name="LifestyleTags" id="finalTags" value="@currentTags" />

                <div class="mt-5">
                    <button type="submit" class="btn w-100 py-3 fw-bold fs-5 text-white" style="background-color: #009688; border-radius: 50px;">
                        XÁC NHẬN SỞ THÍCH VÀ TÌM PHÒNG
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const buttons = document.querySelectorAll('.tag-btn');
        const inputTags = document.getElementById('finalTags');
        let selectedTags = inputTags.value.split(',').filter(t => t.trim() !== "");

        buttons.forEach(btn => {
            btn.addEventListener('click', function() {
                const value = this.getAttribute('data-value');
                this.classList.toggle('active');
                if(selectedTags.includes(value)) {
                    selectedTags = selectedTags.filter(t => t !== value);
                } else {
                    selectedTags.push(value);
                }
                inputTags.value = selectedTags.join(',');
            });
        });
    </script>
</body>
</html>