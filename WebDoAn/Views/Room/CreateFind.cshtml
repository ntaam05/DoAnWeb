@model WebDoAn.Models.RoomPost
@{
    ViewData["Title"] = "Đăng bài tìm người";
}

<h2 class="mb-3">Đăng Bài Tìm Người Ở Ghép</h2>

<form method="post" class="w-75">
    <div class="mb-3">
        <label class="form-label">Tiêu đề</label>
        <input name="Title" class="form-control" value="@Model.Title" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <textarea name="Description" class="form-control" rows="5">@Model.Description</textarea>
    </div>

    <button type="submit" class="btn btn-primary">Đăng</button>
    <a class="btn btn-outline-secondary ms-2" asp-controller="Room" asp-action="FindFeed">Quay lại</a>
</form>