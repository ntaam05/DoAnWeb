@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header text-center py-4 border-0" style="background-color: var(--primary-teal); color: white;">
                    <h3 class="fw-bold mb-0"><i class="bi bi-box-arrow-in-right"></i> Chào mừng trở lại!</h3>
                    <p class="mb-0 mt-1 small text-white-50">Vui lòng đăng nhập để tiếp tục</p>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control focus-teal" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope"></i> Địa chỉ Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Password" class="form-control focus-teal" autocomplete="current-password" aria-required="true" placeholder="password" id="loginPassword" />
                            <label asp-for="Input.Password" class="text-muted"><i class="bi bi-shield-lock"></i> Mật khẩu</label>
                            <button type="button" class="btn btn-sm btn-outline-secondary position-absolute" id="toggleLoginPassword" style="top:10px; right:10px; z-index:10;">
                                <i class="bi bi-eye" id="loginToggleIcon"></i>
                            </button>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input class="form-check-input focus-teal" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted" asp-for="Input.RememberMe">Nhớ tài khoản</label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none fw-bold" style="color: var(--primary-teal);">Quên mật khẩu?</a>
                        </div>

                        <button id="login-submit" type="submit" class="btn text-white w-100 py-3 fw-bold rounded-pill shadow-sm hover-teal-dark" style="background-color: var(--primary-teal);">
                            ĐĂNG NHẬP
                        </button>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <span class="text-muted small">Chưa có tài khoản? </span>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color: var(--primary-teal);">Đăng ký ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .focus-teal:focus {
        border-color: var(--primary-teal);
        box-shadow: 0 0 0 0.25rem rgba(0, 150, 136, 0.25);
    }

    .hover-teal-dark:hover {
        background-color: var(--primary-teal-hover) !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var btn = document.getElementById('toggleLoginPassword');
            var pwd = document.getElementById('loginPassword');
            var icon = document.getElementById('loginToggleIcon');
            if (!btn || !pwd) return;
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    icon.className = 'bi bi-eye-slash';
                } else {
                    pwd.type = 'password';
                    icon.className = 'bi bi-eye';
                }
            });
        })();
    </script>
}