@model WebDoAn.Models.RoomPost
@using Microsoft.AspNetCore.Http
@using System.Reflection

@{
    ViewData["Title"] = "Thảo luận";
    var currentUserEmail = Context.Session.GetString("CURRENT_USER_EMAIL");
    var chatMessages = ViewBag.Comments;
}

@functions {
    public object GetProp(object obj, string propName)
    {
        if (obj == null) return null;
        var prop = obj.GetType().GetProperty(propName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
        return prop?.GetValue(obj);
    }
    public string GetPropString(object obj, string propName) => GetProp(obj, propName)?.ToString() ?? "";
    public int? GetPropInt(object obj, string propName)
    {
        var val = GetProp(obj, propName);
        if (val == null) return null;
        return (val is int i) ? i : (int.TryParse(val.ToString(), out var result) ? result : null);
    }
    public DateTime? GetPropDate(object obj, string propName)
    {
        var val = GetProp(obj, propName);
        if (val == null) return null;
        return (val is DateTime dt) ? dt : (DateTime.TryParse(val.ToString(), out var result) ? result : null);
    }

    // Hàm rút gọn tin nhắn reply
    public string SafePreview(string text, int maxLen = 40)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        text = text.Replace("\r", " ").Replace("\n", " ").Trim();
        return text.Length <= maxLen ? text : text.Substring(0, maxLen) + "...";
    }

    // Hàm tìm tin nhắn gốc để lấy nội dung reply nếu DB chưa lưu sẵn nội dung
    public object FindMessageById(dynamic chatMessages, int? id)
    {
        if (chatMessages == null || id == null) return null;
        foreach (var item in chatMessages)
        {
            if (GetPropInt(item, "Id") == id) return item;
        }
        return null;
    }
}

<style>
    :root {
        --primary-teal: #009688;
        --chat-bg: #f8f9fa;
        --msg-teal: #14a298;
        --reply-border: #00bcd4;
    }

    .chat-container-main {
        display: flex;
        flex-direction: column;
        height: 550px;
        background-color: var(--chat-bg);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .chat-window {
        flex-grow: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .chat-footer-form {
        background: white;
        padding: 15px;
        border-top: 1px solid #eee;
        position: relative;
    }

    .avatar-chat-circle {
        width: 34px !important;
        height: 34px !important;
        min-width: 34px !important;
        flex-shrink: 0 !important;
        border-radius: 50% !important;
        object-fit: cover !important;
        margin-right: 8px;
        border: 1px solid #ddd;
    }

    .msg-group {
        display: flex;
        max-width: 85%;
        position: relative;
        margin-bottom: 8px;
    }

    .msg-group-other {
        align-items: flex-end;
    }

    .msg-group-me {
        margin-left: auto;
        flex-direction: column;
        align-items: flex-end;
    }

    .msg-other-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .nickname-chat {
        font-size: 0.75rem;
        font-weight: 600;
        color: #65676b;
        margin-left: 5px;
        margin-bottom: 2px;
    }

    .bubble {
        padding: 10px 16px;
        border-radius: 18px;
        font-size: 0.95rem;
        position: relative;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        width: fit-content !important;
        min-width: 65px !important;
        margin-bottom: 12px;
    }

    .bubble-other {
        background: white;
        color: #050505;
        border-bottom-left-radius: 4px;
    }

    .bubble-me {
        background-color: var(--msg-teal);
        color: white;
        border-bottom-right-radius: 4px;
        align-self: flex-end;
    }

    /* HIỂN THỊ TIN NHẮN TRÍCH DẪN (REPLY) */
    .reply-quote {
        font-size: 0.8rem;
        background: rgba(0,0,0,0.05);
        padding: 6px 10px;
        border-left: 3px solid var(--reply-border);
        border-radius: 8px;
        margin-bottom: 6px;
        opacity: 0.85;
    }

    .bubble-me .reply-quote {
        background: rgba(255,255,255,0.15);
        color: #f0f0f0;
    }

    .reaction-badge {
        position: absolute;
        bottom: -12px;
        right: 8px;
        background: white;
        border-radius: 15px;
        padding: 2px 5px;
        font-size: 0.9rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.25);
        display: none;
        z-index: 10;
        border: 1px solid #f0f0f0;
        line-height: 1;
    }

        .reaction-badge.active {
            display: block;
        }

    .msg-group-me .reaction-badge {
        right: auto;
        left: 8px;
    }

    .reaction-bar {
        position: absolute;
        top: -42px;
        background: white;
        border-radius: 25px;
        padding: 5px 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        display: none;
        gap: 12px;
        z-index: 100;
        border: 1px solid #eee;
    }

    .msg-group:hover .reaction-bar {
        display: flex;
    }

    .msg-group-me .reaction-bar {
        right: 0;
    }

    .msg-group-other .reaction-bar {
        left: 0;
    }

    .reaction-item {
        cursor: pointer;
        transition: transform 0.2s;
        font-size: 1.3rem;
    }

        .reaction-item:hover {
            transform: scale(1.5);
        }

    .msg-tools {
        display: flex;
        gap: 10px;
        margin-top: -5px;
        font-size: 0.68rem;
        color: #8a8d91;
        padding: 0 5px;
    }

    .btn-reply-action {
        cursor: pointer;
        font-weight: 600;
    }

        .btn-reply-action:hover {
            color: var(--primary-teal);
        }

    .reply-preview-box {
        display: none;
        background: #f0f2f5;
        padding: 8px 12px;
        border-left: 4px solid var(--primary-teal);
        border-radius: 8px;
        margin-bottom: 10px;
    }

        .reply-preview-box.show {
            display: block;
        }

    .chat-input-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f0f2f5;
        border-radius: 20px;
        padding: 5px 15px;
    }

    .chat-text-input {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
    }

    .send-btn-chat {
        background: var(--primary-teal);
        color: white;
        border: none;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 20px;">
                <h5 class="fw-bold mb-3" style="color: var(--primary-teal);"><i class="bi bi-info-circle-fill"></i> Thông tin thảo luận</h5>
                <h4 class="fw-bold">@Model.Title</h4>
                <p class="text-secondary small">@Model.Description</p>
                <hr>
                <div class="small text-muted">Bởi: <strong>@Model.OwnerId.Split('@')[0]</strong></div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="chat-container-main bg-white shadow-sm">
                <div class="chat-window" id="chatWindow">
                    @if (chatMessages != null)
                    {
                        foreach (var msg in chatMessages)
                        {
                            var email = GetPropString(msg, "UserEmail");
                            var nickname = GetPropString(msg, "Nickname");
                            var content = GetPropString(msg, "Content");
                            var avatar = GetPropString(msg, "Avatar") ?? "https://i.pravatar.cc/150?img=3";
                            var time = GetPropDate(msg, "CreatedAt");
                            var msgId = GetPropInt(msg, "Id");
                            bool isMe = (email == currentUserEmail);

                            // LẤY DỮ LIỆU REPLY
                            var replyId = GetPropInt(msg, "ReplyToCommentId");
                            var replyToNickname = GetPropString(msg, "ReplyToNickname");
                            var replyToContent = GetPropString(msg, "ReplyToContent");

                            // Nếu DB chưa có trường Tên/Nội dung reply, tự động dò tìm trong danh sách
                            if (replyId != null && string.IsNullOrWhiteSpace(replyToContent))
                            {
                                var repliedMsg = FindMessageById(chatMessages, replyId);
                                if (repliedMsg != null)
                                {
                                    replyToNickname = GetPropString(repliedMsg, "Nickname");
                                    if (string.IsNullOrWhiteSpace(replyToNickname))
                                    {
                                        var rEmail = GetPropString(repliedMsg, "UserEmail");
                                        replyToNickname = !string.IsNullOrEmpty(rEmail) ? rEmail.Split('@')[0] : "Ai đó";
                                    }
                                    replyToContent = GetPropString(repliedMsg, "Content");
                                }
                            }

                            // LẤY DỮ LIỆU REACTION ĐÃ LƯU TRONG DATABASE (Giả sử bạn đặt tên cột là Reaction)
                            var savedReaction = GetPropString(msg, "Reaction");

                            <div class="msg-group @(isMe ? "msg-group-me" : "msg-group-other")" data-id="@msgId">
                                @if (!isMe)
                                {
                                    <img src="@avatar" class="avatar-chat-circle" onerror="this.src='https://i.pravatar.cc/150?img=3'" />
                                    <div class="msg-other-content">
                                        <div class="nickname-chat">@nickname</div>
                                        <div class="bubble bubble-other">
                                            <div class="reaction-bar">
                                                <span class="reaction-item" onclick="react('@msgId', '👍')">👍</span>
                                                <span class="reaction-item" onclick="react('@msgId', '❤️')">❤️</span>
                                                <span class="reaction-item" onclick="react('@msgId', '😂')">😂</span>
                                                <span class="reaction-item" onclick="react('@msgId', '😮')">😮</span>
                                            </div>

                                            @* BẢN FIX 1: HIỆN TIN NHẮN TRÍCH DẪN *@
                                            @if (replyId != null && !string.IsNullOrWhiteSpace(replyToContent))
                                            {
                                                <div class="reply-quote">
                                                    <strong>@(string.IsNullOrWhiteSpace(replyToNickname) ? "Người dùng" : replyToNickname)</strong>:
                                                    <span>@SafePreview(replyToContent)</span>
                                                </div>
                                            }

                                            @content

                                            @* BẢN FIX 2: LOAD ICON TỪ DATABASE (NẾU CÓ) *@
                                            <div class="reaction-badge @(!string.IsNullOrEmpty(savedReaction) ? "active" : "")" id="react-@msgId">
                                                @savedReaction
                                            </div>
                                        </div>
                                        <div class="msg-tools">
                                            <span>@(time?.ToString("HH:mm"))</span>
                                            <span class="btn-reply-action" onclick="setReply('@msgId', '@nickname', '@content')">Trả lời</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="bubble bubble-me">
                                        <div class="reaction-bar">
                                            <span class="reaction-item" onclick="react('@msgId', '👍')">👍</span>
                                            <span class="reaction-item" onclick="react('@msgId', '❤️')">❤️</span>
                                            <span class="reaction-item" onclick="react('@msgId', '😂')">😂</span>
                                            <span class="reaction-item" onclick="react('@msgId', '😮')">😮</span>
                                        </div>

                                        @* BẢN FIX 1: HIỆN TIN NHẮN TRÍCH DẪN *@
                                        @if (replyId != null && !string.IsNullOrWhiteSpace(replyToContent))
                                        {
                                            <div class="reply-quote">
                                                <strong>@(string.IsNullOrWhiteSpace(replyToNickname) ? "Người dùng" : replyToNickname)</strong>:
                                                <span>@SafePreview(replyToContent)</span>
                                            </div>
                                        }

                                        @content

                                        @* BẢN FIX 2: LOAD ICON TỪ DATABASE *@
                                        <div class="reaction-badge @(!string.IsNullOrEmpty(savedReaction) ? "active" : "")" id="react-@msgId">
                                            @savedReaction
                                        </div>
                                    </div>
                                    <div class="msg-tools">
                                        <span>@(time?.ToString("HH:mm"))</span>
                                        <span class="btn-reply-action" onclick="setReply('@msgId', 'Bạn', '@content')">Trả lời</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                <div class="chat-footer-form">
                    <div id="replyBox" class="reply-preview-box">
                        <div class="d-flex justify-content-between align-items-center small">
                            <div class="text-truncate">Đang trả lời <strong id="replyName"></strong>: <span id="replyText"></span></div>
                            <button class="btn-close" style="font-size: 0.6rem;" onclick="cancelReply()"></button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(currentUserEmail))
                    {
                        <form method="post" asp-action="AddComment" asp-route-id="@Model.Id">
                            <input type="hidden" name="replyToCommentId" id="replyToCommentId" />
                            <div class="chat-input-wrap">
                                <input name="content" id="msgInput" class="form-control chat-text-input" placeholder="Aa" required autocomplete="off" />
                                <button type="submit" class="send-btn-chat">
                                    <i class="bi bi-send-fill"></i>
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="text-center text-muted small">
                            Vui lòng <a href="/Identity/Account/Login" class="text-teal fw-bold">Đăng nhập</a> để tham gia.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const chatWindow = document.getElementById("chatWindow");
    const replyInput = document.getElementById("replyToCommentId");
    const replyBox = document.getElementById("replyBox");
    const msgInput = document.getElementById("msgInput");

    // Cuộn xuống cuối
    if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;

    function setReply(id, name, content) {
        replyInput.value = id;
        document.getElementById("replyName").innerText = name;
        document.getElementById("replyText").innerText = content;
        replyBox.classList.add("show");
        msgInput.focus();
    }

    function cancelReply() {
        replyInput.value = "";
        replyBox.classList.remove("show");
    }

    // BẢN FIX 2: HÀM REACT CÓ GỌI FETCH API ĐỂ LƯU VÀO DB
    function react(msgId, icon) {
        // 1. Cập nhật giao diện mượt mà ngay lập tức
        const badge = document.getElementById("react-" + msgId);
        if (badge) {
            badge.innerText = icon;
            badge.classList.add("active");
        }

        // 2. Gửi ngầm (AJAX) lên Controller để lưu vào SQL
        // Lưu ý: Đường dẫn /Room/ReactComment này phải khớp với Action trong Controller của bạn
        fetch(`/Room/ReactComment?commentId=${msgId}&icon=${encodeURIComponent(icon)}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => {
            if (!response.ok) {
                console.error("Lỗi: Không thể lưu tương tác vào cơ sở dữ liệu.");
            }
        })
        .catch(error => console.error("Lỗi mạng:", error));
    }
</script>