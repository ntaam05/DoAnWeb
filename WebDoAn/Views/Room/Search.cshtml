@model List<WebDoAn.Models.RoomPost>
@{
    ViewData["Title"] = "Tìm kiếm phòng trọ";

    // =========================================
    // CODE CŨ GIỮ NGUYÊN: Lấy lại trạng thái tìm kiếm từ Controller
    // =========================================
    var keyword = ViewBag.Keyword as string;
    var priceRange = ViewBag.PriceRange as string;
    var selectedHashtags = ViewBag.SelectedHashtags as List<string> ?? new List<string>();

    // =========================================
    // CODE MỚI THÊM: Bắt cờ xem đây có phải là kết quả AI Gợi ý không
    // =========================================
    bool isAIRecommendation = ViewBag.IsAIRecommendation != null && (bool)ViewBag.IsAIRecommendation;
}

<style>
    /* ========================================= */
    /* CODE CSS CŨ GIỮ NGUYÊN */
    /* ========================================= */
    .room-card {
        transition: all 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }

        .room-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,150,136,0.15) !important;
        }

    .price-tag {
        color: #e53935;
        font-weight: 800;
        font-size: 1.3rem;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    /* ========================================= */
    /* CODE CSS MỚI: HIỆU ỨNG TOAST TỰ ĐỘNG TẮT (KHÔNG DÙNG JS) */
    /* ========================================= */
    @@keyframes slideInOut {
        0% {
            top: -100px;
            opacity: 0;
        }
        15% {
            top: 30px;
            opacity: 1;
        }
        85% {
            top: 30px;
            opacity: 1;
        }
        100% {
            top: -100px;
            opacity: 0;
            display: none;
        }
    }

    .ai-toast-custom {
        position: fixed;
        left: 50%;
        transform: translateX(-50%);
        z-index: 99999;
        background: linear-gradient(135deg, #009688, #00796b);
        color: white;
        padding: 15px 30px;
        border-radius: 50px;
        box-shadow: 0 10px 30px rgba(0, 150, 136, 0.4);
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: bold;
        font-size: 1.1rem;
        animation: slideInOut 4.5s ease-in-out forwards; /* Tự động chạy 4.5s rồi biến mất */
        pointer-events: none;
    }
</style>

@if (isAIRecommendation && Model != null && Model.Count > 0)
{
    <div class="ai-toast-custom">
        <i class="bi bi-stars text-warning fs-4"></i>
        <span>Theo sở thích bạn đây là những phòng thích hợp</span>
    </div>
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-teal m-0"><i class="bi bi-search"></i> Phòng trọ tương thích</h2>
        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill fw-bold px-3">
            <i class="bi bi-house"></i> Về trang chủ
        </a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info border-0 shadow-sm text-center py-5 rounded-4 mt-4 bg-white">
            @if (isAIRecommendation)
            {
                <i class="bi bi-emoji-frown fs-1 text-muted d-block mb-3"></i>
                <h4 class="fw-bold text-dark">Không có phòng phù hợp với sở thích của bạn</h4>
                <p class="text-muted">Hãy thử thay đổi sở thích hoặc bớt khắt khe hơn một chút nhé!</p>
                <a href="/Profile/Onboarding" class="btn text-white fw-bold px-4 py-2 mt-3 rounded-pill shadow-sm" style="background-color: #009688;">
                    <i class="bi bi-arrow-repeat"></i> Chọn lại sở thích
                </a>
            }
            else
            {
                <i class="bi bi-search fs-1 text-muted d-block mb-3"></i>
                <h4 class="fw-bold">Không tìm thấy phòng trọ nào phù hợp với yêu cầu của bạn.</h4>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var r in Model)
            {
                var images = r.ImageUrls ?? new List<string>();
                var image = images.FirstOrDefault() ?? "https://picsum.photos/seed/defaultroom/400/300";

                <div class="col">
                    <a class="text-decoration-none" asp-controller="Room" asp-action="Detail" asp-route-id="@r.Id">
                        <div class="card h-100 room-card shadow-sm border-0">
                            <div class="position-relative">
                                <img src="@image" class="card-img-top w-100" style="height:220px; object-fit:cover" alt="Ảnh phòng" onerror="this.onerror=null;this.src='https://picsum.photos/seed/defaultroom/400/300';" />
                                <span class="badge @(r.PostType == "Room" ? "bg-warning text-dark" : "bg-success") position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow">
                                    <i class="bi @(r.PostType == "Room" ? "bi-house-door" : "bi-people")"></i>
                                    @(r.PostType == "Room" ? "Cho thuê" : "Tìm ở ghép")
                                </span>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="card-title text-dark fw-bold text-truncate mb-3" title="@r.Title">@r.Title</h5>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="price-tag">@String.Format("{0:N0} đ", r.Price) <span class="fs-6 text-muted fw-normal">/tháng</span></div>
                                </div>
                                <p class="text-muted text-truncate mb-0" style="font-size: 0.95rem;">@r.Description</p>
                            </div>
                            <div class="card-footer bg-white border-0 p-3 pt-0">
                                <hr class="border-light mt-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="btn btn-sm text-white px-3 w-100 rounded-pill" style="background-color: var(--primary-teal);">Xem chi tiết phòng</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>