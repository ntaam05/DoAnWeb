@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng Ký";
}

<div class="row">
    <div class="col-md-8">
        <h2 class="mb-4">Đăng Ký Tài Khoản</h2>

        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                <input asp-for="Input.Password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.UserType" class="form-label">Bạn là   </label>
                <select asp-for="Input.UserType" class="form-select">
                    <option value="Tenant">Người Thuê</option>
                    <option value="Landlord">Người Cho Thuê</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Input.FullName" class="form-label"></label>
                <input asp-for="Input.FullName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Input.BirthYear" class="form-label"></label>
                <input asp-for="Input.BirthYear" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Input.Gender" class="form-label"></label>
                <select asp-for="Input.Gender" class="form-select">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Hometown" class="form-label"></label>
                <input asp-for="Input.Hometown" class="form-control" list="hometown-list" placeholder="Nhập để tìm nhanh..." />
                <datalist id="hometown-list">
                    <option value="Hà Nội"></option>
                    <option value="TP. Hồ Chí Minh"></option>
                    <option value="Đà Nẵng"></option>
                    <option value="Hải Phòng"></option>
                    <!-- ... thêm các tỉnh khác ... -->
                </datalist>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Avatar" class="form-label"></label>
                <input type="file" asp-for="Input.Avatar" class="form-control" accept="image/*" />
            </div>

            <button type="submit" class="btn btn-primary">Đăng Ký</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ 
        await Html.RenderPartialAsync("_ValidationScriptsPartial"); 
    }
}
