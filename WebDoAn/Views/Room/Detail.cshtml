@model WebDoAn.Models.RoomPost
@using Microsoft.AspNetCore.Http

@{
    var email = Context.Session.GetString("CURRENT_USER_EMAIL");
    var type = Context.Session.GetString("CURRENT_USER_TYPE");
    var comments = ViewBag.Comments as List<WebDoAn.Models.RoomComment>;
    double avg = ViewBag.AvgRate ?? 0.0;
    int ratingCount = ViewBag.RatingCount ?? 0;
    bool isSaved = ViewBag.IsSaved != null && (bool)ViewBag.IsSaved;
    bool hasReviewed = ViewBag.HasReviewed != null && (bool)ViewBag.HasReviewed;

    var images = (Model.ImageUrls != null && Model.ImageUrls.Any())
        ? Model.ImageUrls
        : new List<string> { "https://picsum.photos/seed/defaultroom/900/500" };
}

<div class="row g-4">
    <div class="col-lg-7">
        <div id="roomCarousel" class="carousel slide" data-bs-ride="carousel">
            @if (images.Count > 1)
            {
                <div class="carousel-indicators">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button type="button" data-bs-target="#roomCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
            }

            <div class="carousel-inner bg-light rounded shadow-sm border">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@images[i]"
                             class="d-block w-100"
                             style="height: 450px; object-fit: contain; background-color: #e9ecef;"
                             alt="Ảnh phòng @(i + 1)"
                             onerror="this.onerror=null;this.src='https://picsum.photos/seed/defaultroom/900/500';" />
                    </div>
                }
            </div>

            @if (images.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <h2 class="fw-bold">@Model.Title</h2>

        <div class="fs-4 fw-bold text-danger mb-3">
            @String.Format("{0:N0} đ", Model.Price) <small class="text-muted fs-6">/tháng</small>
        </div>

        @if (!string.IsNullOrEmpty(Model.Hashtags))
        {
            <div class="mb-3 d-flex flex-wrap gap-2">
                @foreach (var tag in Model.Hashtags.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                {
                    <span class="badge bg-light text-dark border border-info rounded-pill px-3 py-2 shadow-sm">
                        <i class="bi bi-tag-fill text-teal me-1"></i>@tag
                    </span>
                }
            </div>
        }

        <p class="mt-3 fs-5">@Model.Description</p>

        <div class="mt-4 mb-4 p-3 bg-light rounded shadow-sm border border-light">
            <h6 class="fw-bold mb-3"><i class="bi bi-geo-alt-fill text-danger fs-5 me-1"></i> Vị trí Bản đồ</h6>
            @if (!string.IsNullOrWhiteSpace(Model.MapLink))
            {
                @if (Model.MapLink.Contains("<iframe"))
                {
                    <div class="ratio ratio-16x9 rounded overflow-hidden shadow-sm">
                        @Html.Raw(Model.MapLink)
                    </div>
                }
                else
                {
                    <a href="@Model.MapLink" target="_blank" class="btn btn-outline-danger w-100 fw-bold py-2">
                        <i class="bi bi-map me-2"></i> Mở xem định vị trên Google Maps
                    </a>
                }
            }
            else
            {
                <div class="text-center text-muted p-3 bg-white rounded">
                    <i class="bi bi-map-fill fs-2 d-block mb-2 opacity-50"></i>
                    <span class="small">Chủ phòng chưa cung cấp định vị bản đồ.</span>
                </div>
            }
        </div>

        <div class="mt-3 mb-3 fs-5">
            ⭐ <b>@avg</b> / 5 Đánh giá <span class="text-muted">(@ratingCount lượt)</span>
        </div>

        @if (!string.IsNullOrEmpty(email))
        {
            @if (!isSaved)
            {
                <form method="post" asp-action="SaveRoom">
                    <input type="hidden" name="roomId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger w-100 fw-bold py-3 fs-5 rounded-pill"><i class="bi bi-heart"></i> LƯU TIN NÀY</button>
                </form>
            }
            else
            {
                <form method="post" asp-action="UnsaveRoom">
                    <input type="hidden" name="roomId" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger w-100 fw-bold py-3 fs-5 rounded-pill shadow-sm"><i class="bi bi-heart-fill"></i> ĐÃ LƯU (BỎ LƯU)</button>
                </form>
            }
        }
    </div>
</div>

<hr class="my-5" />

<h4>Bình luận & Đánh giá</h4>

@if (TempData["AuthError"] != null)
{
    <div class="alert alert-warning">@TempData["AuthError"]</div>
}

@if (email != null && type == "Tenant")
{
    @if (!hasReviewed)
    {
        <form method="post" asp-action="AddComment" asp-route-id="@Model.Id" class="mb-4">
            <div class="mb-2">
                <textarea name="content" class="form-control focus-teal" placeholder="Nhận xét trải nghiệm của bạn..." required></textarea>
            </div>
            <div class="mb-2">
                <select name="rating" class="form-select focus-teal" required>
                    <option value="">Chọn số sao</option>
                    <option value="5">⭐⭐⭐⭐⭐ - Rất tốt</option>
                    <option value="4">⭐⭐⭐⭐ - Tốt</option>
                    <option value="3">⭐⭐⭐ - Bình thường</option>
                    <option value="2">⭐⭐ - Tệ</option>
                    <option value="1">⭐ - Rất tệ</option>
                </select>
            </div>
            <button class="btn text-white fw-bold px-4" style="background-color: var(--primary-teal);">Gửi đánh giá</button>
        </form>
    }
    else
    {
        <div class="alert alert-info">Bạn đã đánh giá phòng này rồi. Mỗi email chỉ được đánh giá 1 lần.</div>
    }
}

@if (comments != null && comments.Count > 0)
{
    @foreach (var c in comments.OrderByDescending(x => x.CreatedAt))
    {
        <div class="border rounded p-3 mb-3 shadow-sm bg-light">
            <div class="fw-bold text-teal"><i class="bi bi-person-circle me-2"></i>@c.UserEmail</div>
            <div class="text-warning my-1">
                @for (int s = 0; s < c.Rating; s++)
                {
                    <span>⭐</span>
                }
            </div>
            <div>@c.Content</div>
            <div class="text-muted small mt-2"><i class="bi bi-clock me-1"></i>@c.CreatedAt</div>
        </div>
    }
}
else
{
    <div class="text-muted fst-italic">Chưa có đánh giá nào cho phòng này.</div>
}