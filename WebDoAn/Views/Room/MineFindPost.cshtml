@model List<WebDoAn.Models.RoomPost>
@{
    ViewData["Title"] = "Bài tìm người của tôi";
}

<h2 class="mb-3">Bài tìm người của tôi</h2>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Bạn chưa đăng bài nào.</div>
    <a class="btn btn-primary" asp-controller="Room" asp-action="CreateFind">Đăng bài</a>
}
else
{
    <div class="list-group">
        @foreach (var p in Model)
        {
            <a class="list-group-item list-group-item-action"
               asp-controller="Room" asp-action="Detail" asp-route-id="@p.Id">
                <div class="fw-semibold">@p.Title</div>
                <div class="text-muted text-truncate">@p.Description</div>
            </a>
        }
    </div>
}