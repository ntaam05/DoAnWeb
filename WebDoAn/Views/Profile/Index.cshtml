@model WebDoAn.Models.UserAccount
@{
    ViewData["Title"] = "Hồ sơ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0">Hồ sơ cá nhân</h2>
    <a class="btn btn-outline-primary btn-sm" asp-controller="Profile" asp-action="Edit">Sửa</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body d-flex gap-4">
        <div>
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl" style="width:110px;height:110px;border-radius:50%;object-fit:cover" />
            }
            else
            {
                <div style="width:110px;height:110px;border-radius:50%;background:#eee;display:flex;align-items:center;justify-content:center;">
                    No Avatar
                </div>
            }
        </div>

        <div class="w-100">
            <div class="mb-2"><strong>Email:</strong> @Model.Email</div>
            <div class="mb-2"><strong>Họ tên:</strong> @(string.IsNullOrWhiteSpace(Model.FullName) ? "Chưa cập nhật" : Model.FullName)</div>
            <div class="mb-2"><strong>Năm sinh:</strong> @(string.IsNullOrWhiteSpace(Model.BirthYear) ? "Chưa cập nhật" : Model.BirthYear)</div>
            <div class="mb-2"><strong>Giới tính:</strong> @(string.IsNullOrWhiteSpace(Model.Gender) ? "Chưa cập nhật" : Model.Gender)</div>
            <div class="mb-2"><strong>Quê quán:</strong> @(string.IsNullOrWhiteSpace(Model.Hometown) ? "Chưa cập nhật" : Model.Hometown)</div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Nhập mã tham gia phòng</h5>

        <form method="post" asp-controller="Profile" asp-action="JoinRoomByCode" class="w-50">
            <div class="mb-3">
                <label>Mã phòng</label>
                <input name="joinCode" class="form-control" placeholder="Nhập mã do chủ trọ cung cấp" required />
            </div>

            <button type="submit" class="btn btn-success">Tham gia phòng</button>
        </form>
    </div>
</div>