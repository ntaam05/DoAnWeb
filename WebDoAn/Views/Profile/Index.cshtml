@model WebDoAn.Models.UserAccount
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-teal p-4 text-white text-center" style="background-color: var(--primary-teal);">
                    <div class="position-relative d-inline-block">
                        <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://i.pravatar.cc/150?img=3" : Model.AvatarUrl)"
                             class="rounded-circle border border-4 border-white shadow"
                             style="width:130px; height:130px; object-fit:cover" />
                        <a asp-action="Edit" class="btn btn-light btn-sm rounded-circle position-absolute bottom-0 end-0 shadow">
                            <i class="bi bi-camera-fill"></i>
                        </a>
                    </div>
                    <h3 class="mt-3 fw-bold mb-0">@(string.IsNullOrWhiteSpace(Model.FullName) ? Model.Email.Split('@')[0] : Model.FullName)</h3>
                    <span class="badge bg-light text-teal rounded-pill px-3 py-1 mt-2 shadow-sm" style="color: var(--primary-teal) !important;">@Model.UserType</span>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase">Email liên hệ</label>
                            <p class="fs-5 border-bottom pb-2">@Model.Email</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase">Năm sinh</label>
                            <p class="fs-5 border-bottom pb-2">@(Model.BirthYear ?? "Chưa cập nhật")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase">Giới tính</label>
                            <p class="fs-5 border-bottom pb-2">@(Model.Gender ?? "Chưa cập nhật")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase">Quê quán</label>
                            <p class="fs-5 border-bottom pb-2">@(Model.Hometown ?? "Chưa cập nhật")</p>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3">
                        <a asp-action="Edit" class="btn btn-teal px-5 py-2 rounded-pill fw-bold" style="background-color: var(--primary-teal); color:white;">Chỉnh sửa hồ sơ</a>

                        @if (Model.UserType == "Tenant")
                        {
                            <button class="btn btn-outline-teal px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#joinRoomModal">Tham gia phòng</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="joinRoomModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/Profile/JoinRoomByCode" method="post" class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Nhập mã tham gia phòng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <input name="joinCode" class="form-control form-control-lg bg-light border-0" placeholder="Mã do chủ trọ cung cấp..." required />
            </div>
            <div class="modal-footer border-0">
                <button type="submit" class="btn btn-teal w-100 py-2 rounded-pill" style="background-color: var(--primary-teal); color:white;">Xác nhận tham gia</button>
            </div>
        </form>
    </div>
</div>