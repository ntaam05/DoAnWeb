@model List<WebDoAn.Models.RoomPost>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Tìm người ở ghép";
    var userType = Context.Session.GetString("CURRENT_USER_TYPE");
}

@* HÀM TÍNH THỜI GIAN THỰC *@
@functions {
#nullable disable
    public string GetRelativeTime(DateTime time)
    {
        var ts = DateTime.Now - time;
        if (ts.TotalSeconds < 60) return "Vừa xong";
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes} phút trước";
        if (ts.TotalHours < 24) return $"{(int)ts.TotalHours} giờ trước";
        if (ts.TotalDays < 30) return $"{(int)ts.TotalDays} ngày trước";
        if (ts.TotalDays < 365) return $"{(int)(ts.TotalDays / 30)} tháng trước";
        return $"{(int)(ts.TotalDays / 365)} năm trước";
    }
#nullable restore
}

<style>
    .feed-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 16px;
        border: 1px solid #f0f0f0;
    }

        .feed-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important;
        }

    .btn-outline-teal {
        color: var(--primary-teal);
        border-color: var(--primary-teal);
    }

        .btn-outline-teal:hover {
            background-color: var(--primary-teal);
            color: white;
        }

    .avatar-placeholder {
        width: 50px;
        height: 50px;
        background-color: #e0f2f1;
        color: var(--primary-teal);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: bold;
        font-size: 1.2rem;
    }
</style>

<div class="container py-4 mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3 bg-light p-4 rounded-4 shadow-sm">
        <div>
            <h2 class="fw-bold m-0 text-dark"><i class="bi bi-people-fill text-teal me-2"></i>Cộng đồng tìm trọ</h2>
            <p class="text-muted m-0 mt-1">Kết nối với những người bạn có cùng nhu cầu thuê phòng.</p>
        </div>

        @* NÚT ĐĂNG TIN THÔNG MINH (Tránh lỗi đá văng ra ngoài) *@
        @if (userType == "Tenant")
        {
            <a class="btn btn-teal fw-bold rounded-pill px-4 py-2" style="background-color: var(--primary-teal); color:white;" asp-controller="Room" asp-action="CreateFind">
                <i class="bi bi-pencil-square me-1"></i> Đăng tin tìm người
            </a>
        }
        else if (string.IsNullOrEmpty(userType))
        {
            <a class="btn btn-outline-teal fw-bold rounded-pill px-4 py-2" href="/Identity/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập để đăng tin
            </a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486747.png" alt="Empty" style="width: 120px; opacity: 0.5;" class="mb-3">
            <h5 class="text-muted fw-normal">Hiện tại chưa có ai đăng bài tìm người ở ghép.</h5>
            <p class="text-muted small">Hãy là người đầu tiên đăng bài nhé!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var p in Model)
            {
                <div class="col">
                    <a class="text-decoration-none" asp-controller="Room" asp-action="Discuss" asp-route-id="@p.Id">
                        <div class="card shadow-sm h-100 feed-card bg-white">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3 gap-3">
                                    <div class="avatar-placeholder shadow-sm">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-dark m-0 line-clamp-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@p.Title</h6>

                                        @* ĐÃ THAY ĐỔI DÒNG NÀY: HIỂN THỊ THỜI GIAN THỰC *@
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i>@GetRelativeTime(p.CreatedAt)</small>

                                    </div>
                                </div>
                                <div class="text-secondary" style="font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @p.Description
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-top p-3 text-center">
                                <span class="btn btn-outline-teal w-100 fw-bold rounded-pill">
                                    <i class="bi bi-chat-dots-fill me-1"></i> Tham gia thảo luận
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>