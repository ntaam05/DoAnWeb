@model List<WebDoAn.Models.UserAccount>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="bi bi-people"></i> Quản lý người dùng</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Loại tài khoản</th>
                        <th>Họ tên</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.Email</strong></td>
                            <td>
                                <span class="badge @(user.UserType == "Landlord" ? "bg-primary" : user.UserType == "Tenant" ? "bg-warning text-dark" : "bg-success")">
                                    @(user.UserType == "Landlord" ? "Người cho thuê" : "Người thuê")
                                </span>
                            </td>
                            <td>@user.FullName</td>
                            <td>
                                @if (user.IsBanned)
                                {
                                    <span class="badge bg-danger">Đã ban</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <form method="post" asp-action="BanUser" style="display:inline;">
                                    <input type="hidden" name="email" value="@user.Email" />
                                    <button type="submit" class="btn btn-sm @(user.IsBanned ? "btn-success" : "btn-warning")">
                                        @(user.IsBanned ? "Bỏ ban" : "Ban")
                                    </button>
                                </form>

                                <form method="post" asp-action="DeleteUser" style="display:inline;" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                    <input type="hidden" name="email" value="@user.Email" />
                                    <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>